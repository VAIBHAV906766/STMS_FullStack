{
  "name": "stms-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "check:prereqs": "node scripts/check-prereqs.js",
    "env:prepare": "node scripts/prepare-env.js",
    "dev": "npm-run-all -s check:prereqs env:prepare db:up db:wait db:migrate -p backend:dev frontend:dev",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "db:up": "docker compose up -d postgres",
    "db:wait": "wait-on tcp:5432",
    "db:migrate": "npm --prefix backend run prisma:push",
    "db:down": "docker compose down",
    "start": "npm run dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "wait-on": "^8.0.1"
  }
}
