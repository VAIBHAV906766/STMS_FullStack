{
  "name": "stms-backend",
  "version": "1.0.0",
  "description": "Backend API for Smart Transport Management System",
  "main": "server.js",
  "scripts": {
    "predev": "npm run prisma:push",
    "dev": "nodemon server.js",
    "prestart": "npm run prisma:push",
    "start": "node server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push --skip-generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.22.0"
  }
}
